            currency: 'INR',
            description: 'Payment for {{ course.title }}'
        })
    });
    
    const data = await response.json();
    
    if (!response.ok) {
        throw new Error(data.error || 'Failed to process UPI payment');
    }
    
    // Redirect to success page or show success message
    window.location.href = '{% url "payment_success" %}';
}

// Initialize PayPal
function initializePayPal() {
    if (typeof paypal === 'undefined') {
        console.error('PayPal SDK not loaded');
        return;
    }
    
    // Clear any existing buttons
    $('#paypal-button-container').empty();
    
    paypal.Buttons({
        createOrder: function(data, actions) {
            return actions.order.create({
                purchase_units: [{
                    amount: {
                        value: '{{ course.price }}',
                        currency_code: 'USD'
                    },
                    description: 'Payment for {{ course.title }}'
                }]
            });
        },
        onApprove: function(data, actions) {
            return actions.order.capture().then(function(details) {
                // Redirect to success page after successful payment
                window.location.href = '{% url "payment_success" %}';
            });
        },
        onError: function(err) {
            console.error('PayPal Error:', err);
            showError('An error occurred with PayPal. Please try another payment method.');
        }
    }).render('#paypal-button-container');
}

// Show error message
function showError(message) {
    const errorElement = $('#card-errors');
    if (errorElement.length) {
        errorElement.text(message).show();
        return;
    }
    
    // Disable button and show loading
    submitButton.prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Processing...');
    
    try {
        const csrfToken = $('[name=csrfmiddlewaretoken]').val();
        const response = await fetch('{% url 'courseplatform:create_upi_payment %}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRFToken': csrfToken
            },
            body: JSON.stringify({
                upi_id: upiId,
                amount: parseFloat('{{ course.discount_price|default:course.price|floatformat:2 }}'),
                currency: 'INR',
                description: 'Payment for {{ course.title|escapejs }}',
                course_id: '{{ course.id }}'
            })
        });
        
        if (!response.ok) {
            const errorData = await response.json().catch(() => ({}));
            throw new Error(errorData.error || `HTTP error! status: ${response.status}`);
        }
        
        const data = await response.json();
        
        if (data.success && data.payment_url) {
            // Redirect to UPI payment URL
            window.location.href = data.payment_url;
        } else {
            throw new Error(data.error || 'Failed to initiate UPI payment');
        }
    } catch (error) {
        console.error('UPI Payment Error:', error);
        showError(error.message || 'An error occurred while processing your UPI payment. Please try again.');
    } finally {
        submitButton.prop('disabled', false).html(originalText);
    }
}

// Handle form submission
async function handleFormSubmit(event) {
    event.preventDefault();
    
    const submitButton = $('#submit-payment');
    const originalText = submitButton.html();
    
    // Disable button and show loading
    submitButton.prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Processing...');
    
    try {
        const { paymentIntent, error } = await stripe.confirmCardPayment(
            document.getElementById('payment-data').dataset.clientSecret,
            {
                payment_method: {
                    card: card,
                    billing_details: {
                        name: '{{ request.user.get_full_name|default:request.user.username|escapejs }}',
                        email: '{{ request.user.email|escapejs }}',
                    }
                }
            }
        );
        
        if (error) {
            showError(error.message);
        } else if (paymentIntent.status === 'succeeded') {
            // Redirect to success page
            window.location.href = '{% url "payment_success" %}?payment_intent=' + paymentIntent.id;
        }
    } catch (error) {
        console.error('Payment Error:', error);
        showError('An error occurred while processing your payment.');
    } finally {
        submitButton.prop('disabled', false).html(originalText);
    }
}

    // Helper function to show error messages
    function showError(message) {
