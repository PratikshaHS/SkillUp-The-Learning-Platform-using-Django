        if (errorElement.length) {
            errorElement.text(message).show();
            
            // Scroll to error message
            $('html, body').animate({
                scrollTop: errorElement.offset().top - 100
            }, 500);
        } else {
            console.error('Error element not found');
        }
    }

    // Initialize Stripe
    if (typeof Stripe !== 'undefined') {
        // Get the client secret from the data attribute
        const clientSecret = document.getElementById('payment-data')?.dataset.clientSecret;
        if (!clientSecret) {
            console.error('Stripe client secret is missing');
            return;
        }

        // Initialize Stripe with your publishable key
        stripe = Stripe('{{ STRIPE_PUBLIC_KEY }}');
        
        // Create an Elements instance
        elements = stripe.elements();
        
        // Create card element
        const style = {
            base: {
                color: '#32325d',
                fontFamily: '"Helvetica Neue", Helvetica, sans-serif',
                fontSmoothing: 'antialiased',
                fontSize: '16px',
                '::placeholder': {
                    color: '#aab7c4'
                }
            },
            invalid: {
                color: '#fa755a',
                iconColor: '#fa755a'
            }
        };

        // Create an instance of the card Element
        card = elements.create('card', {style: style});
        
        // Add an instance of the card Element into the `card-element` <div>
        const cardElement = document.getElementById('card-element');
        if (cardElement) {
            card.mount('#card-element');
        }
        
        // Handle real-time validation errors from the card Element
        card.on('change', function(event) {
            const displayError = document.getElementById('card-errors');
            if (event.error) {
                displayError.textContent = event.error.message;
            } else {
                displayError.textContent = '';
            }
        });
    }

    // Initialize Stripe with your public key
    const stripePublicKey = '{{ STRIPE_PUBLIC_KEY|default:'' }}';
    if (!stripePublicKey) {
        showError('Payment processing is not properly configured. Please contact support.');
        return;
    }

    // Initialize Stripe
    const stripe = Stripe(stripePublicKey);
    const elements = stripe.elements();

    // Get the client secret from the data attribute
    const paymentDataElement = document.getElementById('payment-data');
    if (!paymentDataElement) {
        showError('Payment data not found. Please refresh the page and try again.');
        return;
    }

    // Style the card element
    const style = {
        base: {
            color: '#32325d',
            fontFamily: '"Helvetica Neue", Helvetica, sans-serif',
            fontSmoothing: 'antialiased',
            fontSize: '16px',
            '::placeholder': {
                color: '#aab7c4'
            }
        },
        invalid: {
            color: '#fa755a',
            iconColor: '#fa755a'
        }
    };

    // Create an instance of the card Element
    const card = elements.create('card', {style: style});

    // Add an instance of the card Element into the `card-element` <div>
    card.mount('#card-element');

    // Handle real-time validation errors from the card Element
  card.on('change', function(event) {
    const displayError = document.getElementById('card-errors');
    if (event.error) {
      displayError.textContent = event.error.message;
      displayError.style.display = 'block';
    } else {
      displayError.textContent = '';
      displayError.style.display = 'none';
    }
  });

  // Handle form submission
  const form = document.getElementById('payment-form');
  if (form) {
    form.addEventListener('submit', async function(event) {
      event.preventDefault();
      
      const submitButton = document.getElementById('submit-payment');
      if (submitButton) {
        submitButton.disabled = true;
        submitButton.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Processing...';
      }
      
      const clientSecret = paymentDataElement ? paymentDataElement.dataset.clientSecret : null;
      if (!clientSecret) {
        console.error('No client secret found');
        const errorElement = document.getElementById('card-errors');
        if (errorElement) {
          errorElement.textContent = 'Payment processing is not available. Please try again later.';
          errorElement.style.display = 'block';
        }
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.innerHTML = 'Pay ₹{{ course.discount_price|default:course.price|floatformat:2 }}';
        }
        return;
      }
      
      try {
        // Confirm the card payment
        const {error, paymentIntent} = await stripe.confirmCardPayment(clientSecret, {
          payment_method: {
            card: card,
            billing_details: {
              name: '{{ request.user.get_full_name|default:request.user.username|escapejs }}',
              email: '{{ request.user.email|escapejs }}',
            }
          }
        });
        
        if (error) {
          // Show error to your customer
          const errorElement = document.getElementById('card-errors');
          if (errorElement) {
            errorElement.textContent = error.message || 'An error occurred while processing your payment.';
            errorElement.style.display = 'block';
          }
          
          if (submitButton) {
            submitButton.disabled = false;
            submitButton.innerHTML = 'Pay ₹{{ course.discount_price|default:course.price|floatformat:2 }}';
          }
        } else if (paymentIntent.status === 'succeeded') {
          // The payment has been processed successfully
          // Redirect to success page or show success message
          window.location.href = '{% url "courseplatform:payment_success" %}?payment_intent=' + paymentIntent.id;
        }
      } catch (err) {
        console.error('Payment error:', err);
        const errorElement = document.getElementById('card-errors');
        if (errorElement) {
          errorElement.textContent = 'An unexpected error occurred. Please try again.';
          errorElement.style.display = 'block';
        }
        
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.innerHTML = 'Pay ₹{{ course.discount_price|default:course.price|floatformat:2 }}';
        }
      }
    });
  }
    return;
  }
  
  const stripe = Stripe(stripePublicKey);
  const elements = stripe.elements();
  
  // Style the card element
      fontSize: '16px',
      '::placeholder': {
        color: '#aab7c4'
      }
    },
    invalid: {
      color: '#fa755a',
      iconColor: '#fa755a'
    }
  };
  
  // Create an instance of the card Element
  const card = elements.create('card', {style: style});
  
  // Add an instance of the card Element into the `card-element` <div>
  card.mount('#card-element');
  
  // Handle real-time validation errors from the card Element
  card.on('change', function(event) {
    const displayError = document.getElementById('card-errors');
    if (event.error) {
      displayError.textContent = event.error.message;
      displayError.style.display = 'block';
    } else {
      displayError.textContent = '';
      displayError.style.display = 'none';
    }
  });
  
  // Handle form submission
  const form = document.getElementById('payment-form');
  if (form) {
    form.addEventListener('submit', function(event) {
      event.preventDefault();
      
      const submitButton = document.getElementById('submit-payment');
      if (submitButton) {
        submitButton.disabled = true;
        submitButton.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Processing...';
      }
      
      const clientSecret = '{{ client_secret|default:'' }}';
      if (!clientSecret) {
        console.error('No client secret found');
        const errorElement = document.getElementById('card-errors');
        if (errorElement) {
          errorElement.textContent = 'Payment processing is not available. Please try again later.';
          errorElement.style.display = 'block';
        }
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.innerHTML = 'Pay ₹{{ course.discount_price|default:course.price|floatformat:2 }}';
        }
        return;
      }
      
      // Confirm the card payment
      stripe.confirmCardPayment(clientSecret, {
        payment_method: {
          card: card,
          billing_details: {
            name: '{{ request.user.get_full_name|default:request.user.username|escapejs }}',
            email: '{{ request.user.email|escapejs }}',
          }
        }
      }).then(function(result) {
        if (result.error) {
          // Show error to your customer
          const errorElement = document.getElementById('card-errors');
          if (errorElement) {
            errorElement.textContent = result.error.message || 'An error occurred while processing your payment.';
            errorElement.style.display = 'block';
          }
          
          if (submitButton) {
            submitButton.disabled = false;
            submitButton.innerHTML = 'Pay ₹{{ course.discount_price|default:course.price|floatformat:2 }}';
          }
        } else {
          // The payment has been processed!
          if (result.paymentIntent.status === 'succeeded') {
            // Redirect to success page or show success message
            window.location.href = '{% url "courseplatform:payment_success" %}?payment_intent=' + result.paymentIntent.id;
          }
        }
      });
    });
  }
  
  const clientSecret = paymentDataElement.dataset.clientSecret;
  if (!clientSecret) {
    console.error('Client secret is missing!');
    return;
  }
  
  // Define the style for the card element
  const style = {
    base: {
      fontSize: '16px',
      color: '#32325d',
      '::placeholder': {
        color: '#aab7c4'
      }
    },
    invalid: {
      color: '#fa755a',
      iconColor: '#fa755a'
    }
  };
  
  // Create an instance of the card Element
  const card = elements.create('card', {style: style});
  
  // Add an instance of the card Element into the `card-element` <div>
  card.mount('#card-element');
  
  // Handle real-time validation errors from the card Element
  card.on('change', function(event) {
    const displayError = document.getElementById('card-errors');
    if (event.error) {
      displayError.textContent = event.error.message;
      displayError.style.display = 'block';
    } else {
      displayError.textContent = '';
      displayError.style.display = 'none';
    }
  });
  
  // Handle form submission
  const form = document.getElementById('payment-form');
// Handle form submission
async function handleFormSubmit(event) {
    event.preventDefault();
    
    // Disable the submit button to prevent multiple submissions
      const submitButton = document.getElementById('submit-payment');
      const errorElement = document.getElementById('card-errors');
      
      if (!submitButton || !errorElement) {
        console.error('Required form elements not found');
        return;
      }
      
      submitButton.disabled = true;
      submitButton.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Processing...';
      
      try {
        // Confirm the card payment
        const { error, paymentIntent } = await stripe.confirmCardPayment(clientSecret, {
          payment_method: {
            card: card,
            billing_details: {
              name: '{{ request.user.get_full_name|default:request.user.username }}',
              email: '{{ request.user.email }}',
            },
          },
        });

        if (error) {
          // Show error to your customer
          errorElement.textContent = error.message;
          errorElement.style.display = 'block';
          submitButton.disabled = false;
          submitButton.innerHTML = 'Pay ₹{{ course.discount_price|default:course.price|floatformat:2 }}';
        } else if (paymentIntent && paymentIntent.status === 'succeeded') {
          // Successful payment
          window.location.href = '{% url "courseplatform:payment_success" %}?payment_intent=' + paymentIntent.id;
        }
      } catch (error) {
        console.error('Error:', error);
        if (errorElement) {
          errorElement.textContent = 'An unexpected error occurred. Please try again.';
          errorElement.style.display = 'block';
        }
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.innerHTML = 'Pay ₹{{ course.discount_price|default:course.price|floatformat:2 }}';
        }
      }
    });
  }
  
  // Client secret is already passed from the view
  const clientSecret = '{{ client_secret|default:'' }}';
  if (!clientSecret) {
    console.error('No client secret found');
    const errorElement = document.getElementById('card-errors');
    if (errorElement) {
      errorElement.textContent = 'Payment processing is not available. Please try again later.';
      errorElement.style.display = 'block';
    }
  }
  
  // Close the document.ready function
  }); // End of $(document).ready()
  
  // Toggle password visibility for CVV with animation
  const togglePassword = document.querySelector('.toggle-password');
  if (togglePassword) {
    togglePassword.addEventListener('click', function() {
      const passwordInput = document.querySelector('#cvv');
      const icon = this.querySelector('i');
      
      if (passwordInput.type === 'password') {
        passwordInput.type = 'text';
        icon.classList.remove('bi-eye');
        icon.classList.add('bi-eye-slash');
      } else {
        passwordInput.type = 'password';
        icon.classList.remove('bi-eye-slash');
        icon.classList.add('bi-eye');
      }
      
      // Trigger reflow for smooth transition
      void passwordInput.offsetWidth;
    });
    
      // Focus styles are handled by CSS
  }
  
  // Handle payment method selection
  document.querySelectorAll('.payment-method').forEach(method => {
    method.addEventListener('click', function() {
      // Remove active class from all methods
      document.querySelectorAll('.payment-method').forEach(m => {
        m.classList.remove('active');
      });
      
      // Add active class to clicked method
      this.classList.add('active');
      
      // Hide all forms
      document.querySelectorAll('.payment-form').forEach(form => {
        form.classList.add('d-none');
      });
      
      // Show selected form
      const formId = this.id + '-form';
      document.getElementById(formId).classList.remove('d-none');
      
      // Check the corresponding radio button
      const radioId = this.id + '-radio';
      document.getElementById(radioId).checked = true;
    });
  });
  
  // Format card number with real-time validation
    // Format card number
    document.getElementById('card-number')?.addEventListener('input', function(e) {
        let value = e.target.value.replace(/\s+/g, '');
        if (value.length > 0) {
            value = value.match(new RegExp('.{1,4}', 'g')).join(' ');
        }
        e.target.value = value;
        
        // Update card type icon
        const cardType = detectCardType(value.replace(/\s+/g, ''));
        const cardIcon = document.getElementById('card-type');
        if (cardIcon) {
            cardIcon.className = 'card-type-icon ' + cardType;
        }
      // Basic card type detection
      const cardType = detectCardType(value.replace(/\s/g, ''));
      const cardIcon = document.getElementById('card-type-icon');
      if (cardType) {
        cardIcon.className = `bi bi-credit-card-${cardType} me-2`;
        e.target.classList.remove('is-invalid');
        e.target.classList.add('is-valid');
      } else {
        cardIcon.className = 'bi bi-credit-card me-2';
        e.target.classList.remove('is-valid');
      }
    }
    e.target.value = value;
  });
  
  // Detect card type based on number
  function detectCardType(number) {
    const cardTypes = {
      visa: /^4/,
      mastercard: /^5[1-5]/,
      amex: /^3[47]/,
      discover: /^(6011|65|64[4-9]|622)/
    };
    
    for (const [type, pattern] of Object.entries(cardTypes)) {
      if (pattern.test(number)) {
        return type;
      }
    }
    return '';
  }
  
    // Format and validate expiry date
    document.getElementById('expiry-date')?.addEventListener('input', function(e) {
        let value = e.target.value.replace(/\D/g, '');
    // Auto-insert slash after MM
    if (value.length >= 2) {
      value = value.substring(0, 2) + '/' + value.substring(2, 4);
      
      // Validate month
      const month = parseInt(value.substring(0, 2), 10);
      if (month < 1 || month > 12) {
        e.target.classList.add('is-invalid');
        e.target.classList.remove('is-valid');
      } else {
        e.target.classList.remove('is-invalid');
        
        // Basic future date validation
        if (value.length === 5) {
          const [mm, yy] = value.split('/');
          const currentYear = new Date().getFullYear() % 100;
          const currentMonth = new Date().getMonth() + 1;
          
          if (parseInt(yy, 10) < currentYear || 
              (parseInt(yy, 10) === currentYear && parseInt(mm, 10) < currentMonth)) {
            e.target.classList.add('is-invalid');
          } else {
            e.target.classList.add('is-valid');
          }
        }
      }
    } else if (value.length === 2) {
      value += '/';
    }
    
    e.target.value = value;
  });
  
  // Process PayPal payment
  function processPayPal() {
    // In a real app, this would redirect to PayPal
    alert('Redirecting to PayPal...');
  }
  
  // Process UPI payment
  function processUPI() {
    const upiId = document.getElementById('upi-id').value;
    if (!upiId) {
      alert('Please enter a valid UPI ID');
      return;
    }
    // In a real app, this would initiate a UPI payment
    alert('Initiating UPI payment for ' + upiId);
  }
  
      // Handle UPI app selection
    document.querySelectorAll('.upi-app').forEach(app => {
        app.addEventListener('click', function() {
            // In a real app, this would open the selected UPI app
      alert('Opening ' + this.querySelector('img').alt + '...');
    });
  });
  
  // Form submission
  document.getElementById('payment-form').addEventListener('submit', function(e) {
    e.preventDefault();
    // In a real app, this would process the payment
    alert('Processing payment...');
    // You would typically call your payment processor's API here
    // For example, with Stripe: stripe.createToken(card).then(...)
  });
</script>
